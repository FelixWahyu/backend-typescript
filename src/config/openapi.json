{
  "openapi": "3.0.0",
  "info": {
    "title": "Backend TypeScript API",
    "version": "1.0.0",
    "description": "Dokumentasi API lengkap untuk backend-typescript Express dengan Prisma ORM dan MySQL/MariaDB.",
    "contact": {
      "name": "Felix"
    }
  },
  "servers": [
    {
      "url": "/api/v1",
      "description": "Base API Path"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Masukkan Access Token JWT Anda (tanpa prefix Bearer, Swagger akan menambahkannya secara otomatis)."
      }
    },
    "schemas": {
      "ApiSuccessResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "message": { "type": "string", "example": "Operasi berhasil" },
          "data": { "type": "object", "nullable": true },
          "errors": { "type": "array", "items": {}, "example": null },
          "meta": { "type": "object", "nullable": true }
        }
      },
      "ApiErrorResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "message": { "type": "string", "example": "Pesan error detail" },
          "data": { "type": "object", "example": null },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field": { "type": "string", "example": "email" },
                "message": { "type": "string", "example": "Format email tidak valid" }
              }
            },
            "nullable": true
          }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Check status kesehatan server",
        "tags": ["Utility"],
        "responses": {
          "200": {
            "description": "Server berjalan dengan normal",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiSuccessResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "summary": "Mendaftarkan user baru",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "username", "email", "password"],
                "properties": {
                  "name": { "type": "string", "example": "John Doe" },
                  "username": { "type": "string", "example": "johndoe" },
                  "email": { "type": "string", "example": "johndoe@example.com" },
                  "password": { "type": "string", "example": "P@ssword123" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Registrasi berhasil" },
          "400": { "description": "Validasi input gagal" },
          "409": { "description": "Username atau Email sudah terdaftar" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Login ke aplikasi",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "example": "johndoe@example.com" },
                  "password": { "type": "string", "example": "P@ssword123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login berhasil, mengembalikan token" },
          "401": { "description": "Email atau Password salah" }
        }
      }
    },
    "/auth/refresh-token": {
      "post": {
        "summary": "Perbarui access token menggunakan refresh token",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refreshToken"],
                "properties": {
                  "refreshToken": { "type": "string", "example": "token_string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Access token berhasil diperbarui" },
          "401": { "description": "Refresh token tidak valid atau expired" }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "summary": "Logout dari aplikasi",
        "tags": ["Auth"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refreshToken"],
                "properties": {
                  "refreshToken": { "type": "string", "example": "token_string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Logout berhasil, token di-revoke" },
          "401": { "description": "Unauthorized / Token expired" }
        }
      }
    },
    "/auth/me": {
      "get": {
        "summary": "Ambil data profil pengguna yang sedang login",
        "tags": ["Auth"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Data profil berhasil didapatkan" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/users": {
      "get": {
        "summary": "Ambil daftar user dengan pagination (Membutuhkan Login)",
        "tags": ["User"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 1 } }
        ],
        "responses": {
          "200": { "description": "Berhasil mendapatkan daftar user" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "summary": "Buat user baru (Hanya Admin)",
        "tags": ["User"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "email", "password"],
                "properties": {
                  "name": { "type": "string", "nullable": true, "example": "Admin Kece" },
                  "username": { "type": "string", "example": "adminkeceu" },
                  "email": { "type": "string", "example": "admin@example.com" },
                  "password": { "type": "string", "example": "secretPassword123" },
                  "role": { "type": "string", "enum": ["USER", "ADMIN"], "default": "USER" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User baru berhasil dibuat" },
          "403": { "description": "Forbidden - Hanya Admin" }
        }
      }
    },
    "/users/{id}": {
      "get": {
        "summary": "Detail data user (Membutuhkan Login)",
        "tags": ["User"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Berhasil mendapatkan detail user" },
          "404": { "description": "User tidak ditemukan" }
        }
      },
      "put": {
        "summary": "Update data user (Hanya Admin)",
        "tags": ["User"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "nullable": true },
                  "username": { "type": "string" },
                  "email": { "type": "string" },
                  "role": { "type": "string", "enum": ["USER", "ADMIN"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Update user berhasil" }
        }
      },
      "delete": {
        "summary": "Hapus user (Hanya Admin)",
        "tags": ["User"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "User berhasil dihapus" }
        }
      }
    },
    "/users/{id}/edit": {
      "get": {
        "summary": "Ambil data user untuk dimuat di form edit (Membutuhkan Login)",
        "tags": ["User"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Data user berhasil diambil" }
        }
      }
    },
    "/categories": {
      "get": {
        "summary": "Ambil daftar semua kategori",
        "tags": ["Category"],
        "responses": {
          "200": { "description": "Daftar kategori berhasil diambil" }
        }
      },
      "post": {
        "summary": "Buat kategori baru (Hanya Admin)",
        "tags": ["Category"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["category_name"],
                "properties": {
                  "category_name": { "type": "string", "example": "Elektronik" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Kategori berhasil dibuat" }
        }
      }
    },
    "/categories/{id}": {
      "get": {
        "summary": "Detail kategori",
        "tags": ["Category"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Kategori ditemukan" },
          "404": { "description": "Kategori tidak ditemukan" }
        }
      },
      "put": {
        "summary": "Update nama kategori (Hanya Admin)",
        "tags": ["Category"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["category_name"],
                "properties": {
                  "category_name": { "type": "string", "example": "Gadget & HP" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Kategori berhasil diupdate" }
        }
      },
      "delete": {
        "summary": "Hapus kategori (Hanya Admin)",
        "tags": ["Category"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Kategori berhasil dihapus" }
        }
      }
    },
    "/categories/{id}/edit": {
      "get": {
        "summary": "Ambil data kategori untuk dimuat di form edit (Hanya Admin)",
        "tags": ["Category"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Data kategori berhasil diambil" }
        }
      }
    },
    "/products": {
      "get": {
        "summary": "Daftar produk dengan pagination & filter",
        "tags": ["Product"],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 10 } },
          { "name": "categoryId", "in": "query", "schema": { "type": "string" } },
          { "name": "search", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Daftar produk didapatkan" }
        }
      },
      "post": {
        "summary": "Buat produk baru beserta upload gambar (Hanya Admin)",
        "tags": ["Product"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["product_name", "price"],
                "properties": {
                  "product_name": { "type": "string", "example": "Smart TV OLED" },
                  "price": { "type": "number", "example": 7500000 },
                  "categoryId": { "type": "string", "example": "uuid-kategori" },
                  "description": { "type": "string", "example": "TV pintar berteknologi layar OLED." },
                  "image": { "type": "string", "format": "binary", "description": "Gambar utama produk (Max 2MB)" },
                  "images": {
                    "type": "array",
                    "items": { "type": "string", "format": "binary" },
                    "description": "Galeri gambar tambahan (Maksimal 5 gambar)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Produk berhasil dibuat" }
        }
      }
    },
    "/products/{id}": {
      "get": {
        "summary": "Detail produk",
        "tags": ["Product"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Produk ditemukan" }
        }
      },
      "put": {
        "summary": "Update data produk & gambar utama (Hanya Admin)",
        "tags": ["Product"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "product_name": { "type": "string" },
                  "price": { "type": "number" },
                  "categoryId": { "type": "string" },
                  "description": { "type": "string" },
                  "image": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Produk berhasil diupdate" }
        }
      },
      "delete": {
        "summary": "Hapus produk beserta seluruh gambarnya (Hanya Admin)",
        "tags": ["Product"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Produk berhasil dihapus" }
        }
      }
    },
    "/products/{id}/edit": {
      "get": {
        "summary": "Ambil data produk untuk form edit (Hanya Admin)",
        "tags": ["Product"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Data produk didapatkan" }
        }
      }
    },
    "/products/{id}/images": {
      "post": {
        "summary": "Tambahkan gambar-gambar galeri ke produk (Hanya Admin)",
        "tags": ["Product"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "images": {
                    "type": "array",
                    "items": { "type": "string", "format": "binary" },
                    "description": "Maksimal 5 gambar galeri tambahan"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Gambar galeri berhasil ditambahkan" }
        }
      }
    },
    "/products/images/{imageId}": {
      "delete": {
        "summary": "Hapus satu gambar galeri produk (Hanya Admin)",
        "tags": ["Product"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "imageId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Gambar galeri berhasil dihapus" }
        }
      }
    },
    "/blogs": {
      "get": {
        "summary": "Daftar semua blog",
        "tags": ["Blog"],
        "responses": {
          "200": { "description": "Daftar blog didapatkan" }
        }
      },
      "post": {
        "summary": "Buat blog baru (Hanya Admin)",
        "tags": ["Blog"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title"],
                "properties": {
                  "title": { "type": "string", "example": "Panduan Belajar TypeScript" },
                  "description": { "type": "string", "example": "Deskripsi lengkap belajar TS." },
                  "published": { "type": "boolean", "default": false }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Blog berhasil dibuat" }
        }
      }
    },
    "/blogs/{id}": {
      "get": {
        "summary": "Detail blog",
        "tags": ["Blog"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Blog didapatkan" }
        }
      },
      "put": {
        "summary": "Update data blog (Hanya Admin)",
        "tags": ["Blog"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "published": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Blog diupdate" }
        }
      },
      "delete": {
        "summary": "Hapus blog (Hanya Admin)",
        "tags": ["Blog"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Blog dihapus" }
        }
      }
    },
    "/blogs/{id}/edit": {
      "get": {
        "summary": "Ambil data blog untuk form edit (Hanya Admin)",
        "tags": ["Blog"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Data blog didapatkan" }
        }
      }
    },
    "/posts": {
      "get": {
        "summary": "Daftar posts dengan pagination & search",
        "tags": ["Post"],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 10 } },
          { "name": "search", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Daftar posts didapatkan" }
        }
      },
      "post": {
        "summary": "Buat post baru (Hanya Admin)",
        "tags": ["Post"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title", "authorId"],
                "properties": {
                  "title": { "type": "string", "example": "Judul Postingan Baru" },
                  "content": { "type": "string", "example": "Konten artikel yang panjang..." },
                  "published": { "type": "boolean", "default": false },
                  "authorId": { "type": "string", "description": "UUID dari User pembuat" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Post berhasil dibuat" }
        }
      }
    },
    "/posts/{id}": {
      "get": {
        "summary": "Detail postingan",
        "tags": ["Post"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Post ditemukan" }
        }
      },
      "put": {
        "summary": "Update data postingan (Hanya Admin)",
        "tags": ["Post"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "content": { "type": "string" },
                  "published": { "type": "boolean" },
                  "authorId": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Post berhasil diupdate" }
        }
      },
      "delete": {
        "summary": "Hapus postingan (Hanya Admin)",
        "tags": ["Post"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Post berhasil dihapus" }
        }
      }
    },
    "/posts/{id}/edit": {
      "get": {
        "summary": "Ambil data postingan untuk form edit (Hanya Admin)",
        "tags": ["Post"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Data post didapatkan" }
        }
      }
    }
  }
}
